rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // New originals layout.
    match /uploads/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == uid || request.auth.token.admin == true);
    }

    // Generated thumbs layout. Clients should not write directly.
    match /thumbs/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Legacy layout kept for backward compatibility and cleanup tasks.
    match /users/{uid}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && (request.auth.uid == uid || request.auth.token.admin == true);
    }
  }
}
